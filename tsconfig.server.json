{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "esnext",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false
  },
  "include": ["src/app.ts", "src/controllers/**/*", "src/routes/**/*", "src/utils/**/*", "src/middleware/**/*"]
}
